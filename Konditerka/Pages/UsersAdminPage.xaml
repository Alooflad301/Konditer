<Page x:Class="Konditerka.Pages.UsersAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="600"
      Title="UsersAdminPage">

    <Page.Resources>
        <Style x:Key="AdminCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontFamily"      Value="Arial Black"/>
            <Setter Property="Background"      Value="#FF91009A"/>
            <Setter Property="BorderBrush"     Value="#FFE0C14D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#FF82DBFF"/>
            <Setter Property="Padding"         Value="6,2"/>
        </Style>
        <Style x:Key="AdminComboItem" TargetType="ComboBoxItem">
            <Setter Property="FontFamily"  Value="Arial Black"/>
            <Setter Property="Foreground"  Value="#FF420046"/>
            <Setter Property="Background"  Value="White"/>
            <Setter Property="Padding"     Value="8,4"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FF420046">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False"
                  SelectionChanged="UsersGrid_SelectionChanged"
                  FontFamily="Arial Black" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"     Binding="{Binding IdUser}"           Width="70"/>
                <DataGridTextColumn Header="Логин"  Binding="{Binding NameUser}"          Width="*"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}"          Width="150"/>
                <DataGridTextColumn Header="Email"  Binding="{Binding Email}"             Width="*"/>
                <DataGridTextColumn Header="Роль"   Binding="{Binding Roles.NameRole}"    Width="150"/>
                <DataGridTextColumn Header="Город"  Binding="{Binding Cities.NameCity}"   Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Метки -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,2">
                <TextBlock Text="Логин"  Foreground="#FF82DBFF" FontFamily="Arial Black" Width="158"/>
                <TextBlock Text="Почта"  Foreground="#FF82DBFF" FontFamily="Arial Black" Width="228"/>
                <TextBlock Text="Пароль" Foreground="#FF82DBFF" FontFamily="Arial Black" Width="128"/>
                <TextBlock Text="Роль"   Foreground="#FF82DBFF" FontFamily="Arial Black" Width="158"/>
                <TextBlock Text="Город"  Foreground="#FF82DBFF" FontFamily="Arial Black" Width="158"/>
            </StackPanel>

            <!-- Поля -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,5,5">
                <TextBox x:Name="UserNameBox" Width="150" Height="30" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial Black" MaxLength="50" ToolTip="Логин"
                         Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBox x:Name="EmailBox" Width="220" Height="30" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial Black" MaxLength="100" ToolTip="Почта"
                         Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBox x:Name="PasswordBox" Width="120" Height="30" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial Black" MaxLength="50" ToolTip="Пароль"
                         Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <ComboBox x:Name="RoleBox" Width="150" Margin="0,0,8,0"
                          Style="{StaticResource AdminCombo}"
                          DisplayMemberPath="NameRole"
                          SelectedValuePath="IdRole">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource AdminComboItem}"/>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <ComboBox x:Name="CityBox" Width="150" Margin="0,0,8,0"
                          Style="{StaticResource AdminCombo}"
                          DisplayMemberPath="NameCity"
                          SelectedValuePath="IdCity">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource AdminComboItem}"/>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,8,0"
                        Click="EditButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Удалить" Width="100" Height="30"
                        Click="DeleteButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
