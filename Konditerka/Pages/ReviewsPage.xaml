<Page x:Class="Konditerka.Pages.ReviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
      Title="ReviewsPage">

    <Page.Resources>
        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FF420046" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="ProductTitleBlock"
                       FontFamily="Arial Black" FontSize="22"
                       Foreground="#FF82DBFF" TextWrapping="Wrap"/>
            <TextBlock x:Name="AvgRatingBlock"
                       FontFamily="Arial Black" FontSize="14"
                       Foreground="#FFE0C14D" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Форма добавления отзыва -->
        <Border Grid.Row="1" Background="#FF5A005F" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Ваш отзыв" FontFamily="Arial Black"
                           Foreground="#FF82DBFF" FontSize="15" Margin="0,0,0,8"/>

                <!-- Звёздочки -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="Star1" Content="☆" Style="{StaticResource StarButton}"
                            Foreground="#FFE0C14D" Click="Star_Click" Tag="1"/>
                    <Button x:Name="Star2" Content="☆" Style="{StaticResource StarButton}"
                            Foreground="#FFE0C14D" Click="Star_Click" Tag="2"/>
                    <Button x:Name="Star3" Content="☆" Style="{StaticResource StarButton}"
                            Foreground="#FFE0C14D" Click="Star_Click" Tag="3"/>
                    <Button x:Name="Star4" Content="☆" Style="{StaticResource StarButton}"
                            Foreground="#FFE0C14D" Click="Star_Click" Tag="4"/>
                    <Button x:Name="Star5" Content="☆" Style="{StaticResource StarButton}"
                            Foreground="#FFE0C14D" Click="Star_Click" Tag="5"/>
                    <TextBlock x:Name="RatingLabel" VerticalAlignment="Center"
                               Margin="10,0,0,0" FontFamily="Arial Black"
                               Foreground="White" FontSize="13"/>
                </StackPanel>

                <!-- Текст отзыва -->
                <TextBox x:Name="CommentBox"
                         Height="70" Padding="8" TextWrapping="Wrap"
                         AcceptsReturn="True" MaxLength="500"
                         FontFamily="Arial Black"
                         Background="#FF91009A" BorderBrush="#FFE0C14D"
                         Foreground="#FF82DBFF"
                         ToolTip="Напишите ваш отзыв...">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="SubmitButton" Content="Отправить отзыв"
                            Width="160" Height="32"
                            FontFamily="Arial Black" Foreground="Black"
                            Background="#FFE0C14D" Click="SubmitButton_Click"/>
                    <Button Content="Назад к каталогу"
                            Width="160" Height="32" Margin="10,0,0,0"
                            FontFamily="Arial Black" Foreground="Black"
                            Background="#FF91009A" BorderBrush="#FFE0C14D"
                            Click="BackButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Список отзывов -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ReviewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF5A005F" CornerRadius="8"
                                Margin="0,0,0,8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding UserName}"
                                               FontFamily="Arial Black" FontSize="13"
                                               Foreground="#FF82DBFF"/>
                                    <TextBlock Text="{Binding StarsDisplay}"
                                               FontSize="14" Foreground="#FFE0C14D"
                                               Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                               FontFamily="Arial Black" FontSize="11"
                                               Foreground="#FFAAAAAA" Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding Comment}"
                                           FontFamily="Arial Black" FontSize="12"
                                           Foreground="White" TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
