<Page x:Class="Konditerka.Pages.OrdersAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="760"
      Title="OrdersAdminPage">

    <Page.Resources>
        <Style x:Key="AdminCombo" TargetType="ComboBox">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="FontFamily"      Value="Arial Black"/>
            <Setter Property="Background"      Value="#FF91009A"/>
            <Setter Property="BorderBrush"     Value="#FFE0C14D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#FF82DBFF"/>
            <Setter Property="Padding"         Value="6,2"/>
        </Style>
        <Style x:Key="AdminComboItem" TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="Foreground" Value="#FF420046"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding"    Value="8,4"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FF420046">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False"
                  SelectionChanged="OrdersGrid_SelectionChanged"
                  FontFamily="Arial Black" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№"      Binding="{Binding IdOrder}"                    Width="60"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding IdUser}"                     Width="100"/>
                <DataGridTextColumn Header="Дата"   Binding="{Binding Data, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                <DataGridTextColumn Header="Сумма"  Binding="{Binding Price, StringFormat=N2}"     Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusOrders.NameStatusOrder}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Метки -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,2">
                <TextBlock Text="ID клиента"  Foreground="#FF82DBFF" FontFamily="Arial Black" Width="98"/>
                <TextBlock Text="Дата заказа" Foreground="#FF82DBFF" FontFamily="Arial Black" Width="148"/>
                <TextBlock Text="Сумма"       Foreground="#FF82DBFF" FontFamily="Arial Black" Width="128"/>
                <TextBlock Text="Статус"      Foreground="#FF82DBFF" FontFamily="Arial Black" Width="188"/>
            </StackPanel>

            <!-- Поля -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,5,5">
                <TextBox x:Name="UserIdBox" Width="90" Height="30" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial Black" MaxLength="10" ToolTip="ID клиента"
                         Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <DatePicker x:Name="OrderDateBox" Width="140" Height="30" Margin="0,0,8,0"
                            FontFamily="Arial Black"/>

                <TextBox x:Name="OrderPriceBox" Width="120" Height="30" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Arial Black" MaxLength="10" ToolTip="Сумма"
                         Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <ComboBox x:Name="StatusBox" Width="180" Margin="0,0,8,0"
                          Style="{StaticResource AdminCombo}"
                          DisplayMemberPath="NameStatusOrder"
                          SelectedValuePath="IdStatusOrder">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource AdminComboItem}"/>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <Button Content="Добавить"  Width="100" Height="30" Margin="0,0,8,0"
                        Click="AddButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,8,0"
                        Click="EditButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Удалить"   Width="100" Height="30"
                        Click="DeleteButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
