<Page x:Class="Konditerka.Pages.DictionaryAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="400" d:DesignWidth="760"
      Title="DictionaryAdminPage">

    <Grid Background="#FF420046">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ItemsGrid"
                  AutoGenerateColumns="False"
                  SelectionChanged="ItemsGrid_SelectionChanged"
                  FontFamily="Arial Black" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding Id}"   Width="80"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
            <TextBox x:Name="NameBox"
                     Width="320" Height="32" VerticalContentAlignment="Center"
                     Margin="0,0,10,0" FontFamily="Arial Black"
                     MaxLength="100" ToolTip="Название"
                     Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Button Content="Добавить"  Width="110" Height="32" Margin="0,0,8,0"
                    Click="AddButton_Click"
                    FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            <Button Content="Сохранить" Width="110" Height="32" Margin="0,0,8,0"
                    Click="EditButton_Click"
                    FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            <Button Content="Удалить"   Width="110" Height="32"
                    Click="DeleteButton_Click"
                    FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
        </StackPanel>
    </Grid>
</Page>
