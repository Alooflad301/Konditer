<Page x:Class="Konditerka.Pages.CheckoutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
      Title="CheckoutPage">

    <Grid Background="#FF420046" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Оформление заказа"
                   FontFamily="Arial Black" FontSize="22"
                   Foreground="#FF82DBFF" Margin="0,0,0,16"/>

        <!-- Способ доставки -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Способ доставки" FontFamily="Arial Black"
                       Foreground="#FF82DBFF" FontSize="15" Margin="0,0,0,6"/>
            <ListBox x:Name="DeliveryList" SelectionChanged="DeliveryList_SelectionChanged"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF5A005F" CornerRadius="8"
                                Margin="0,0,0,4" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding NameDeliveryMethod}"
                                           FontFamily="Arial Black" Foreground="White" FontSize="13"/>
                                <TextBlock Text=" — " Foreground="#FFAAAAAA"/>
                                <TextBlock Text="{Binding PriceDelivery, StringFormat={}{0:N0} ₽}"
                                           FontFamily="Arial Black" Foreground="#FFE0C14D" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Margin="0,2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FFE0C14D"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <!-- Адрес доставки -->
        <StackPanel Grid.Row="2" x:Name="AddressPanel" Visibility="Collapsed" Margin="0,0,0,14">
            <TextBlock Text="Адрес доставки" FontFamily="Arial Black"
                       Foreground="#FF82DBFF" FontSize="15" Margin="0,0,0,6"/>
            <TextBox x:Name="AddressBox" Height="32" Padding="8,4"
                     FontFamily="Arial Black" MaxLength="300"
                     Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF"
                     ToolTip="Улица, дом, квартира">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </StackPanel>

        <!-- Способ оплаты -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="Способ оплаты" FontFamily="Arial Black"
                       Foreground="#FF82DBFF" FontSize="15" Margin="0,0,0,6"/>
            <ListBox x:Name="PaymentList" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF5A005F" CornerRadius="8"
                                Margin="0,0,0,4" Padding="12,8">
                            <TextBlock Text="{Binding NamePaymentMethod}"
                                       FontFamily="Arial Black" Foreground="White" FontSize="13"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Margin="0,2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#FFE0C14D"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <!-- Комментарий -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14">
            <TextBlock Text="Комментарий к заказу (необязательно)"
                       FontFamily="Arial Black" Foreground="#FF82DBFF"
                       FontSize="13" Margin="0,0,0,6"/>
            <TextBox x:Name="CommentBox" Height="55" Padding="8"
                     TextWrapping="Wrap" AcceptsReturn="True" MaxLength="500"
                     FontFamily="Arial Black"
                     Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </StackPanel>

        <!-- Итог -->
        <Border Grid.Row="6" Background="#FF5A005F" CornerRadius="10" Padding="14,10">
            <DockPanel>
                <Button Content="Назад" Width="110" Height="34"
                        DockPanel.Dock="Left"
                        FontFamily="Arial Black" Foreground="Black"
                        Background="#FF91009A" BorderBrush="#FFE0C14D"
                        Click="BackButton_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="TotalBlock"
                               FontFamily="Arial Black" FontSize="16"
                               Foreground="White" VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    <Button Content="Подтвердить заказ" Width="180" Height="34"
                            FontFamily="Arial Black" Foreground="Black"
                            Background="#FFE0C14D" Click="ConfirmButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Page>
